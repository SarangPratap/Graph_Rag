SARVAM_API_KEY=your_sarvam_api_key_here
HF_TOKEN=your_huggingface_token_here

# Local Qdrant (Docker) — used when QDRANT_URL is not set
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant Cloud — set these to use cloud instead of local Docker
# QDRANT_URL=https://your-cluster.qdrant.tech
# QDRANT_API_KEY=your_qdrant_api_key_here

KUZU_DB_PATH=./graphrag.db

# Suppress Prefect's "no flow run id" warning when calling tasks directly from the UI
PREFECT_LOGGING_TO_API_WHEN_MISSING_FLOW=ignore
